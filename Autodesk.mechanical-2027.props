<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <AcadmSdkDir>$(ArxSdkDir)\acadmapi</AcadmSdkDir>
    </PropertyGroup>

    <PropertyGroup>
        <IncludePath>$(AcadmSdkDir)\inc;$(IncludePath)</IncludePath>
        <LibraryPath>$(AcadmSdkDir)\lib-x64;$(LibraryPath)</LibraryPath>
    </PropertyGroup>

    <ItemDefinitionGroup>
        <Link>
            <AdditionalDependencies>iso_stdio_wide_specifiers.lib;rxapi.lib;$(LIB_ACGE);$(LIB_AC1ST);$(LIB_ACDB);accore.lib;acad.lib;acgiapi.lib;acmsymbb_crx.lib;%(AdditionalDependencies)</AdditionalDependencies>
        </Link>
    </ItemDefinitionGroup>
</Project>